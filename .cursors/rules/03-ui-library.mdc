## BaseDataTable

For data tables inside pages use `BaseDataTable` from `apps/backoffice-web/src/components/table/`:

```tsx
import { BaseDataTable, type TableColumn } from "../table/BaseDataTable";
import { PaginationControls } from "../table/PaginationControls";

const columns: TableColumn<Item>[] = [
  { key: "name",  label: "Tên hàng hóa", render: (r) => r.name },
  { key: "price", label: "Đơn giá",      render: (r) => r.sellingPrice.toLocaleString("vi-VN") },
];

<BaseDataTable
  columns={columns}
  rows={items}
  loading={isLoading}
  emptyLabel="Chưa có hàng hóa"
  getRowKey={(r) => r.id}
  renderActions={(r) => <RowActions item={r} />}
/>
<PaginationControls page={page} pageSize={20} total={total} onPageChange={setPage} />
```
