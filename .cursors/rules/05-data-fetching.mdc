## TanStack Query patterns

### Query (read)

```tsx
import { useQuery } from "@tanstack/react-query";
import { erpApi, requireErpData } from "../lib/erp-api";

function useInventoryItems(page: number, search: string) {
  return useQuery({
    queryKey: ["inventory-items", page, search],   // include all variables
    queryFn: () =>
      requireErpData(
        erpApi.GET("/admin/entities/inventory-items/records", {
          params: { query: { page, pageSize: 20, search } },
        })
      ),
    staleTime: 30_000,    // match the global default
    placeholderData: (prev) => prev,   // keep previous data while fetching next page
  });
}
```

### Mutation (create / update / delete)

```tsx
import { useMutation, useQueryClient } from "@tanstack/react-query";

function useDeleteItem() {
  const qc = useQueryClient();
  return useMutation({
    mutationFn: (id: string) =>
      requireErpSuccess(
        erpApi.DELETE("/inventory/items/{id}", { params: { path: { id } } })
      ),
    onSuccess: () => {
      // Invalidate related queries so UI refreshes automatically
      void qc.invalidateQueries({ queryKey: ["inventory-items"] });
    },
  });
}

// Usage
const { mutate: deleteItem, isPending } = useDeleteItem();
<Button onClick={() => deleteItem(selectedId)} disabled={isPending}>Xóa</Button>
```

### QueryKey conventions

Always use an array. First element = resource name, rest = filters/IDs:

```ts
["inventory-items"]                    // list (all)
["inventory-items", page, search]      // list with filters
["inventory-items", "detail", id]      // single record
["customers", orgId]                   // scoped by org
```

Invalidate with prefix to bust all related queries:
```ts
qc.invalidateQueries({ queryKey: ["inventory-items"] });
```

