# ──────────────────────────────────────────────
# ERP Dev Environment
# Copy to .env and adjust values as needed
# ──────────────────────────────────────────────

# ── API ──────────────────────────────────────
PORT=4000
NODE_ENV=development

# Optional: backoffice-web uses this in production builds. In Vite dev, if unset,
# requests default to http://localhost:${PORT} (see apps/backoffice-web/src/lib/api-base.ts).
# VITE_API_BASE_URL=http://localhost:4000

# Optional: pre-fill the login page in Vite dev (see apps/backoffice-web/src/pages/auth/LoginPage.tsx).
# VITE_DEV_ORG_ID=10000000-0000-4000-8000-000000000001
# VITE_DEV_LOGIN_EMAIL=inventory.admin@erp.local
# VITE_DEV_LOGIN_PASSWORD=password123

# Optional: hide OpenAPI UI and /docs-json (Swagger is off automatically in production).
# DISABLE_SWAGGER=1

# Optional: override URL for `pnpm openapi:generate` / `make openapi-generate`.
# OPENAPI_URL=http://127.0.0.1:4000/docs-json

# ── PostgreSQL ───────────────────────────────
# Host port 5433 to avoid conflict with local Postgres on 5432
DB_HOST=localhost
DB_PORT=5433
DB_NAME=erp_dev
DB_USER=erp_user
DB_PASS=erp_secret

# ── Redis ────────────────────────────────────
# Host port 6380 to avoid conflict with local Redis on 6379
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=erp_redis_secret
REDIS_DB=0

# ── Redpanda / Kafka ────────────────────────
# Host port 19092 to avoid conflict with local Kafka on 9092
KAFKA_BROKERS=localhost:19092
KAFKA_PORT=19092
KAFKA_CLIENT_ID=erp-api
KAFKA_CONSUMER_GROUP_PREFIX=erp-api

# SASL auth — opt in by setting KAFKA_AUTH_ENABLE=true. When enabled,
# KAFKA_SASL_USERNAME and KAFKA_SASL_PASSWORD are required.
# Mechanism: plain | scram-sha-256 | scram-sha-512 (default scram-sha-256).
# KAFKA_AUTH_ENABLE=false
# KAFKA_SASL_MECHANISM=scram-sha-256
# KAFKA_SASL_USERNAME=
# KAFKA_SASL_PASSWORD=
# KAFKA_SSL=false

# ── JWT ──────────────────────────────────────
JWT_SECRET=change-me-in-production
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800

# ── POS ──────────────────────────────────────
POS_VARIANCE_THRESHOLD=50

# ── Inventory ────────────────────────────────
ADJUSTMENT_APPROVAL_THRESHOLD=100

# ── Expenses ─────────────────────────────────
EXPENSE_APPROVAL_THRESHOLD=1000
