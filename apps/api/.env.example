# ── API ──────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── PostgreSQL (host port 5433 to avoid conflict with local 5432) ──
DB_HOST=localhost
DB_PORT=5433
DB_NAME=erp_dev
DB_USER=erp_user
DB_PASS=erp_secret

# ── Redis (host port 6380 to avoid conflict with local 6379) ──
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=erp_redis_secret
REDIS_DB=0

# ── Redpanda / Kafka (host port 19092 to avoid conflict with local 9092) ──
KAFKA_BROKERS=localhost:19092
KAFKA_CLIENT_ID=erp-api
KAFKA_CONSUMER_GROUP_PREFIX=erp-api

# SASL auth — opt in by setting KAFKA_AUTH_ENABLE=true. When enabled,
# KAFKA_SASL_USERNAME and KAFKA_SASL_PASSWORD are required.
# Mechanism: plain | scram-sha-256 | scram-sha-512 (default scram-sha-256).
# KAFKA_AUTH_ENABLE=false
# KAFKA_SASL_MECHANISM=scram-sha-256
# KAFKA_SASL_USERNAME=
# KAFKA_SASL_PASSWORD=
# KAFKA_SSL=false

# ── JWT ──────────────────────────────────────
JWT_SECRET=change-me-in-production
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800
