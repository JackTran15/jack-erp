{
  "name": "@erp/root",
  "private": true,
  "scripts": {
    "clean": "pnpm -r exec -- sh -c 'rm -rf dist' && find . \\( -type f -name 'tsconfig.tsbuildinfo' -o -name '*.tsbuildinfo' \\) ! -path '*/node_modules/*' -delete 2>/dev/null; exit 0",
    "build:shared": "pnpm --filter @erp/shared-interfaces build && pnpm --filter @erp/shared-kafka-client build",
    "postinstall": "pnpm run build:shared",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "dev:api": "pnpm run build:shared && pnpm --filter @erp/api dev",
    "dev:backoffice": "pnpm --filter @erp/backoffice-web dev",
    "dev:pos": "pnpm --filter @erp/pos-web dev",
    "test:e2e": "pnpm --filter @erp/api test:e2e",
    "migration:generate": "cd apps/api && npx typeorm-ts-node-commonjs migration:generate -d src/database/data-source.ts",
    "migration:run": "pnpm --filter @erp/api migration:run",
    "migration:revert": "pnpm --filter @erp/api migration:revert",
    "migration:show": "pnpm --filter @erp/api migration:show",
    "migration:create": "cd apps/api && npx typeorm-ts-node-commonjs migration:create",
    "schema:sync": "pnpm --filter @erp/api schema:sync",
    "schema:drop": "pnpm --filter @erp/api schema:drop",
    "seed:inventory": "pnpm --filter @erp/api seed:inventory",
    "seed:dev-admin": "pnpm --filter @erp/api seed:dev-admin",
    "contract:check": "ts-node --compiler-options '{\"module\":\"commonjs\"}' scripts/contract-check.ts",
    "docs:entities:manifest": "ts-node --compiler-options '{\"module\":\"commonjs\"}' scripts/generate-entity-docs.ts",
    "docs:entities:markdown": "node scripts/generate-entity-markdown.js",
    "docs:entities": "pnpm docs:entities:manifest && pnpm docs:entities:markdown",
    "openapi:generate": "pnpm --filter @erp/api-client run generate",
    "entity:visual": "typeorm-visual create",
    "entity:visual:generate": "typeorm-visual generate"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.18.1",
  "devDependencies": {
    "ts-node": "^10.9.2",
    "typeorm-visual": "^1.0.0",
    "typescript": "^5.9.3"
  }
}
